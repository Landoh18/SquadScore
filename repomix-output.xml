          <div
            style={{
              textAlign: 'center',
              marginTop: '14px',
              fontSize: totalSize,
              color: 'var(--color-text-tertiary)',
            }}
          >
            Station score ·{' '}
            <span style={{ color: 'var(--color-text-primary)' }}>
              {stationHits}/{totalAtStation}
            </span>
          </div>
